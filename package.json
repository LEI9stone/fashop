{
  "name": "fashop",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:server": "turbo dev --filter=@fashop/server",
    "dev:buyer": "turbo dev --filter=@fashop/buyer",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
